# Supabase Configuration
# Get these values from your Supabase project dashboard: https://supabase.com

NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Google Drive API Configuration (OAuth 2.0)
# Follow the setup steps in GOOGLE_DRIVE_SETUP.md

GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REFRESH_TOKEN=your_google_refresh_token_here
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id_here
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback



